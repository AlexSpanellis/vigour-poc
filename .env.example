# Copy this file to .env and fill in values before running locally
# Never commit .env to version control

# ---- GCP ----
GCP_PROJECT=your-gcp-project-id
GCS_BUCKET=your-gcp-project-id-vigour-poc
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ---- Database ----
DATABASE_URL=postgresql://vigour:vigour@localhost:5432/vigour

# ---- Redis / Celery ----
REDIS_URL=redis://localhost:6379/0

# ---- Storage ----
UPLOAD_DIR=/tmp/vigour_uploads
OUTPUT_DIR=data/annotated
CONFIGS_DIR=configs/test_configs

# ---- Pipeline ----
DEFAULT_FPS=15
DEVICE=cuda   # or cpu
